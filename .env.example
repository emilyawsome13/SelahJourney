APP_ORIGIN=http://localhost:4173
BIND_HOST=127.0.0.1
SESSION_SECRET=change-this-session-secret

# Optional persistent storage location. On Render, use a mounted disk path such as /var/data.
DATA_DIR=

# Google OAuth 2.0 web app credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# HTTPS email delivery for hosted deployments such as Render
RESEND_API_KEY=
# Use onboarding@resend.dev only for testing with the same email address as your Resend account.
# Do not use a Gmail address here. For public delivery, verify your own domain in Resend.
RESEND_FROM=Selah Journey <onboarding@resend.dev>

# Gmail SMTP for local development or environments that allow SMTP
GMAIL_SMTP_EMAIL=yourgmail@gmail.com
GMAIL_SMTP_APP_PASSWORD=
MAIL_FROM=Selah Journey <onboarding@resend.dev>
